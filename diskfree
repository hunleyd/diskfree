#!/bin/bash

# diskfree - A script to monitor and report changes in disk usage.
#
# This script scans specified directories for their disk usage, compares the results 
# with the previous run, and generates a report of added, deleted, or changed 
# allocations. It can then mail this report to a specified user.
#
# Version: 2.1.2
# Author: Douglas Hunley, 2013-2026

set -o pipefail
set -u

VERSION="diskfree 2.1.2 - (c) Douglas Hunley, 2013-2026"

# Configuration and State Variables
DIRS=""               # List of directories to monitor (defaults to /* if empty)
EXTENSION=""          # Optional suffix for output files (set via -e)
GNU=no                # Whether GNU coreutils (du, df) are available
MAILER=/usr/sbin/sendmail # Path to the system's mailer
MAILTO=root           # Recipient for the disk usage report
OUTPUT=/tmp           # Directory where temporary and log files are stored
PARANOID=no           # If 'yes', reports on the entire directory tree (-p flag)
REPORT_REGARDLESS=no  # If 'yes', sends a report even if no changes were detected (-r flag)

# Process command line arguments
while getopts ":pvrd:m:l:e:" opt; do
	case $opt in
		p)
			# Paranoid mode: report on the entire directory tree instead 
			# of just summarizing at the top level.
			PARANOID=yes
			;;
		m)
			# Set the recipient email address for the report.
			# Use '@' to print to stdout instead of mailing.
			MAILTO="$OPTARG"
			;;
		d)
			# Report on a specific set of directories.
			# This captures all arguments until the next option (starting with '-').
			unset DONE
			if [[ "${OPTARG:0:1}" == "-" ]]; then
				true
			else
				DIRS="$OPTARG"
			fi
			
			# Collect additional directory paths provided after the initial -d argument.
			while [[ -z "${DONE:-}" ]]; do
				if [[ "${!OPTIND:0:1}" == "-" ]] || [[ -z "${!OPTIND:-}" ]]; then
					DONE=yes;
				else
					DIRS="$DIRS ${!OPTIND}"
					OPTIND=$((OPTIND+1))
				fi
			done
			unset DONE
			;;
		l)
			# Specify the directory where temporary and output files should be written.
			OUTPUT="$OPTARG"
			;;
		e)
			# Set a custom extension for the output files.
			EXTENSION=".${OPTARG}"
			;;
		r)
			# Force a report even if no changes in disk usage are found.
			REPORT_REGARDLESS=yes
			;;
		v)
			# Display version information and exit.
			echo "$VERSION"
			exit 0
			;;
		\?)
			# Display usage instructions and exit with an error.
			echo "$VERSION"
			echo
			echo "USAGE: $(basename "$0") [-p] [-m email_address] [-v] [-l logdir] [-r] [-d dirs]"
			echo "  -p - 'I am a paranoid admin' mode. Report on entire directory tree"
			echo "  -m - email address to send report to (or '@' to print to stdout)"
			echo "  -l - specify directory to store log files in (Default: /tmp)"
			echo "  -e - special extension to append to output"
			echo "  -v - print version info and exit"
			echo "  -r - create and mail report even if empty (so you know it ran)"
			echo "  -d - report on specified directories instead of subdirectories of /"
			exit 1
			;;
	esac
done

# Adjust positional parameters to remove options processed by getopts
shift $((OPTIND - 1))

# Define paths for temporary files used during processing
PREVIOUS="${OUTPUT}/$(basename "$0").previous${EXTENSION}" # Data from the last successful run
CURRENT="${OUTPUT}/$(basename "$0").current${EXTENSION}"   # Data collected in the current run
DELETED="${OUTPUT}/$(basename "$0").deleted${EXTENSION}"   # List of directories removed since last run
ADDED="${OUTPUT}/$(basename "$0").added${EXTENSION}"       # List of new directories since last run
CHANGED="${OUTPUT}/$(basename "$0").changed${EXTENSION}"   # List of directories with changed usage
WORKFILE="${OUTPUT}/$(basename "$0").work${EXTENSION}"     # Temporary scratch file for diffs/processing
REPORT="${OUTPUT}/$(basename "$0").report${EXTENSION}"     # The final report content to be mailed/printed

# Set default directory search if none was specified via -d
if [[ -z "${DIRS}" ]]; then
	DIRS="/*"
fi

# Security check: Remove any symbolic links that might be mimicking our temporary files.
for file in "$PREVIOUS" "$CURRENT" "$DELETED" "$ADDED" "$CHANGED" "$WORKFILE" "$REPORT" "$REPORT.2"
do
	if [[ -L "$file" ]] ; then
		rm -f "$file"
	fi
done

# Detect if GNU versions of 'du' and 'df' are available for better output formatting.
if du --version >/dev/null 2>&1; then
	GNU=yes
fi

# Configure arguments for 'du' based on tool availability and paranoid mode.
if [[ "$GNU" == "yes" ]] ; then
	DU_ARGS="-h" # Human-readable output if GNU is available
else
	DU_ARGS="-k" # Kilobytes output for POSIX-compliant du
fi
if [[ "$PARANOID" == "no" ]] ; then
	DU_ARGS="-s $DU_ARGS" # Summary mode: only report top-level directories
fi

# Select the appropriate 'df' command and flags for the current platform.
case $(uname -s) in
	HP-UX)
		# Use 'bdf' (Berkeley df) on HP-UX for more readable output.
		DF="bdf"
		;;
	*)
		DF="df"
		;;
esac
if [[ "$GNU" == "yes" ]] ; then
	DF="$DF -h" # Human-readable output for GNU df
else
	DF="$DF -k" # Kilobytes output for standard df
fi

# Collect disk usage data for the specified directories.
cd /
# Note: We exclude /proc as its size reported by du is inconsistent and unreliable.
# shellcheck disable=SC2086
du $DU_ARGS $DIRS 2>/dev/null | grep -v $'\t/proc' > "$CURRENT"
# Sort the current data by directory name for consistent comparison.
sort -k 2 "$CURRENT" > "$CURRENT.sorted${EXTENSION}" && mv "$CURRENT.sorted${EXTENSION}" "$CURRENT"

# Check if there is data from a previous run to compare against.
if [[ -s "$PREVIOUS" ]] ; then
	# Extract directory names (column 2) for comparison.
	awk '{print $2}' "$PREVIOUS" > "$PREVIOUS.tmp${EXTENSION}"
	awk '{print $2}' "$CURRENT" > "$CURRENT.tmp${EXTENSION}"

	# Identify directories that were present previously but are now missing.
	comm -23 "$PREVIOUS.tmp${EXTENSION}" "$CURRENT.tmp${EXTENSION}" > "$DELETED.tmp${EXTENSION}"
	while read -r line
	do
		# Retrieve the full 'du' output line for each deleted directory.
		grep $'\t'"${line}$" "$PREVIOUS" >> "$DELETED" || true
	done < "$DELETED.tmp${EXTENSION}"
	rm "$DELETED.tmp${EXTENSION}" >/dev/null 2>&1

	# Identify directories that were not present previously but are now present.
	comm -13 "$PREVIOUS.tmp${EXTENSION}" "$CURRENT.tmp${EXTENSION}" > "$ADDED.tmp${EXTENSION}"
	while read -r line
	do
		# Retrieve the full 'du' output line for each added directory.
		grep $'\t'"${line}$" "$CURRENT" >> "$ADDED" || true
	done < "$ADDED.tmp${EXTENSION}"
	rm "$ADDED.tmp${EXTENSION}" >/dev/null 2>&1

	# Identify directories present in both runs to check for size changes.
	comm -12 "$PREVIOUS.tmp${EXTENSION}" "$CURRENT.tmp${EXTENSION}" > "$CHANGED.tmp${EXTENSION}"
	while read -r line
	do
		# Store entries for shared directories from both runs for diffing.
		grep $'\t'"${line}$" "$PREVIOUS" >> "$PREVIOUS.CURRENT${EXTENSION}" || true
		grep $'\t'"${line}$" "$CURRENT" >> "$CHANGED.CURRENT${EXTENSION}" || true
	done < "$CHANGED.tmp${EXTENSION}"
	rm "$CHANGED.tmp${EXTENSION}" >/dev/null 2>&1

	# Use diff to identify which shared directories have changed in size.
	if [[ -f "$PREVIOUS.CURRENT${EXTENSION}" ]] && [[ -f "$CHANGED.CURRENT${EXTENSION}" ]]; then
		diff "$PREVIOUS.CURRENT${EXTENSION}" "$CHANGED.CURRENT${EXTENSION}" > "$WORKFILE"
		rm "$PREVIOUS.CURRENT${EXTENSION}" "$CHANGED.CURRENT${EXTENSION}" >/dev/null 2>&1
	fi

	DIR=
	was=
	# Parse the diff output to generate a summary of changed allocations.
	if [[ -s "$WORKFILE" ]]; then
		while read -r line
		do
			# Extract directory name and size from the diff lines.
			DIR2=$(echo "$line" | awk '{print $3}')
			if [[ "$DIR" == "$DIR2" ]] ; then
				is=$(echo "$line" | awk '{print $2}')
				# If we have both old and new sizes, record the change.
				if [[ "${was}" != "" ]] && [[ "$is" != "$was" ]] ; then
					echo "$DIR is $is was $was" >> "$CHANGED"
				fi
			else
				DIR="$DIR2"
				was=$(echo "$line" | awk '{print $2}')
			fi
		done < <(grep -E '^<|^>' "$WORKFILE")
	fi

	# Construct the body of the report.
	{
		if [[ -s "$CHANGED" ]] ; then
			if [[ "$GNU" == "yes" ]] ; then
				echo "Changed allocations"
			else
				echo "Changed allocations (Kb)"
			fi
			cat "$CHANGED"
			echo
		fi
		if [[ -s "$ADDED" ]] ; then
			if [[ "$GNU" == "yes" ]] ; then
				echo "New allocations"
			else
				echo "New allocations (Kb)"
			fi
			cat "$ADDED"
			echo
		fi
		if [[ -s "$DELETED" ]] ; then
			if [[ "$GNU" == "yes" ]] ; then
				echo "Freed allocations"
			else
				echo "Freed allocations (Kb)"
			fi
			cat "$DELETED"
			echo
		fi
	} >> "$REPORT"
fi

# If a report was generated (i.e., changes were found), finalize and deliver it.
if [[ -s "$REPORT" ]] ; then
	{
		if [[ "$GNU" == "yes" ]] ; then
			echo "Total allocations"
		else
			echo "Total allocations (Kb)"
		fi
		# Include the overall system disk usage (df) at the top of the report.
		# shellcheck disable=SC2086
		$DF
		echo
		cat "$REPORT"
	} > "$REPORT.2"
	mv "$REPORT.2" "$REPORT"
	
	# Deliver the report either to stdout or via email.
	if [[ "${MAILTO}" == "@" ]]; then
		cat "$REPORT"
	else
		( echo "Subject: ${EXTENSION} Disk Usage Report"
		  echo "From: Disk Usage System <nobody>"
		  echo "To: ${MAILTO}"
		  cat "$REPORT"
		) | "$MAILER" "${MAILTO}"
	fi
else
	# If no changes were found but reporting was requested regardless, send a notification.
	if [[ "${REPORT_REGARDLESS}" == "yes" ]] ; then
		( echo "Subject: ${EXTENSION} Disk Usage Report"
		  echo "From: Disk Usage System <nobody>"
		  echo "To: ${MAILTO}"
		  echo "No disk changes to report"
		) | "$MAILER" "${MAILTO}"
	fi
fi

# Rotate current data to 'previous' for comparison in the next run.
mv "$CURRENT" "$PREVIOUS" >/dev/null 2>&1

# Clean up temporary processing files.
for file in "$DELETED" "$ADDED" "$CHANGED" "$WORKFILE" "$CURRENT.tmp${EXTENSION}" "$PREVIOUS.tmp${EXTENSION}" "$REPORT"
do
	rm -f "$file" >/dev/null 2>&1
done

exit 0
